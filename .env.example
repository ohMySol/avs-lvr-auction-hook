# Values are loaded by BOTH dotenv (backend) and `include .env` (Makefile). Make does not strip
# inline `# comments` or surrounding quotes, so keep every value on its own line, bare, with no
# trailing comment. Put explanations on their own comment lines like these.

# Fork source (used by `make anvil-fork` only)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<key>

# Endpoints (the running services talk to the local fork)
RPC_URL=http://127.0.0.1:8545
# Fork preserves the forked chain's id (mainnet fork => 1)
CHAIN_ID=1
REDIS_URL=redis://127.0.0.1:6379

# Contract addresses are NOT set here. DeployFork.s.sol writes deployments/<CHAIN_ID>.json and the
# backend/frontend read it. Override the lookup dir only if needed:
# DEPLOYMENTS_DIR=deployments

# DEPLOYER_PK deploys contracts + is the funded LP / intent user in the demo.
DEPLOYER_PK=0x...
# OPERATOR_PK is the AVS operator signing key (registered operator-set member).
OPERATOR_PK=0x...
# SETTLER_CALLER_PK calls Settler.settle; MUST equal the committed winner (set == OPERATOR_PK).
SETTLER_CALLER_PK=0x...

# Price feed
PRICE_SOURCE=fixed
# currency1 per currency0 in whole tokens. For USDC(c0)/WETH(c1): WETH per USDC, e.g. 0.0005 ~ 2000
# USDC/WETH. Set it slightly off the pool start price (DEPLOY_SQRT_PRICE_X96) to create an arb gap.
FIXED_PRICE=0.0005

# searcher-rpc
INTENT_PORT=8088
